rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Eigener Bereich für diese App: apps/trainingsApp
    // Darunter getrennt nach Umgebung: envs/prod bzw. envs/dev
    // Darunter pro Nutzer: users/{uid}, nur für den jeweils eingeloggten
    // Nutzer lesbar/schreibbar.
    match /apps/trainingsApp/envs/{env}/users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
